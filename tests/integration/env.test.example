# Test Environment Variables for LiteLLM Middleware
# Copy this file to .env and replace with your actual values

# ===========================================
# REQUIRED: Revenium Configuration
# ===========================================

# Your actual Revenium metering API key
REVENIUM_METERING_API_KEY=hak_your_actual_revenium_key_here

# Revenium API base URL
REVENIUM_BASE_URL=https://api.dev.hcapp.io

# ===========================================
# REQUIRED: LiteLLM Proxy Configuration
# ===========================================

# LiteLLM Proxy URL with full endpoint
LITELLM_PROXY_URL=http://localhost:4000/chat/completions

# LiteLLM Proxy API key (if your proxy requires auth)
LITELLM_API_KEY=sk-your_litellm_proxy_key

# ===========================================
# OPTIONAL: Test Configuration
# ===========================================

# Test organization ID
REVENIUM_ORGANIZATION_ID=test_org

# ===========================================
# DEBUG SETTINGS
# ===========================================

# Enable debug logging for tests
REVENIUM_DEBUG=true
REVENIUM_LOG_LEVEL=DEBUG

# Fail loudly during tests (set to false to see errors)
REVENIUM_FAIL_SILENT=false 