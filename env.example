# Revenium LiteLLM Middleware Environment Variables

# ===========================================
# REQUIRED: Revenium Configuration
# ===========================================

# Your Revenium metering API key (starts with "hak_")
# Get this from your Revenium dashboard
REVENIUM_METERING_API_KEY=hak_your_revenium_api_key_here

# Only set this if you need to use a different environment (dev, staging, etc.)
#REVENIUM_METERING_BASE_URL=

# ===========================================
# REQUIRED: LiteLLM Proxy Configuration  
# ===========================================

# LiteLLM Proxy Configuration (for using LiteLLM proxy server)
LITELLM_PROXY_URL="http://localhost:4000"
LITELLM_API_KEY="sk-1234" #litellm key issued as proxy for another provider's key

# ===========================================
# OPTIONAL: Logging and Debugging
# ===========================================

# Log level: DEBUG, INFO, WARNING, ERROR, CRITICAL
REVENIUM_LOG_LEVEL=INFO

# Enable debug mode for detailed logging
# REVENIUM_DEBUG=true

# ===========================================
# OPTIONAL: Performance and Behavior
# ===========================================

# Timeout for Revenium API calls (milliseconds)
# REVENIUM_API_TIMEOUT=5000

# Whether to fail silently if Revenium tracking fails (recommended: true)
# REVENIUM_FAIL_SILENT=true

# Maximum retries for failed Revenium API calls
# REVENIUM_MAX_RETRIES=3

# ===========================================
# LLM Provider API Keys (handled by LiteLLM Proxy)
# ===========================================
# Note: These are typically configured in your LiteLLM Proxy Server
# configuration, not in your Node.js application. Listed here for reference.

# OPENAI_API_KEY=sk_your_openai_key
# ANTHROPIC_API_KEY=your_anthropic_key  
# AZURE_API_KEY=your_azure_key
# AZURE_API_BASE=https://your-resource.openai.azure.com/
# AZURE_API_VERSION=2023-05-15
# COHERE_API_KEY=your_cohere_key
# HUGGINGFACE_API_KEY=your_hf_key